{
  "openapi": "3.1.0",
  "info": {
    "title": "MajorMate API",
    "description": "Global Major-based Study Platform — Backend API\n\n## WebSocket / STOMP (실시간 스톱워치)\n\n연결 엔드포인트: `ws://localhost:8082/ws` (SockJS)\n\n### 구독 토픽\n| 토픽 | 설명 |\n|---|---|\n| `/topic/room.{roomId}` | 방 멤버 상태 브로드캐스트 |\n| `/user/queue/errors` | 개인 에러 메시지 |\n\n### 전송 대상 (prefix: `/app`)\n| 대상 | Payload | 설명 |\n|---|---|---|\n| `/app/stopwatch.start` | `StartStopwatchRequest` | 스톱워치 시작 |\n| `/app/stopwatch.pause` | - | 일시정지 |\n| `/app/stopwatch.resume` | - | 재시작 |\n| `/app/stopwatch.end` | - | 종료 및 DB 저장 |\n| `/app/stopwatch.keyword` | `UpdateKeywordRequest` | 키워드 변경 |\n\n### 브로드캐스트 메시지 타입 (`RoomBroadcastMessage.type`)\n`MEMBER_JOINED` · `MEMBER_LEFT` · `MEMBER_STARTED` · `MEMBER_PAUSED` · `MEMBER_RESUMED` · `MEMBER_ENDED` · `MEMBER_KEYWORD_UPDATED`",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:8082", "description": "Local Dev" }
  ],
  "tags": [
    { "name": "Auth",      "description": "Google OAuth2 인증" },
    { "name": "User",      "description": "사용자 프로필" },
    { "name": "Character", "description": "캐릭터 레이어 시스템" },
    { "name": "Friend",    "description": "친구 코드 & 네트워킹" },
    { "name": "Room",      "description": "전공방 & 커스텀 스터디룸" },
    { "name": "Session",   "description": "스톱워치 세션 (STOMP)" },
    { "name": "Stats",     "description": "학습 통계" },
    { "name": "Admin",     "description": "관리자 전용 API" }
  ],
  "paths": {
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "현재 인증된 사용자 정보 조회",
        "operationId": "getMe",
        "responses": {
          "200": {
            "description": "인증된 사용자",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserResponse" } } }
          },
          "401": { "description": "미인증" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그아웃",
        "operationId": "logout",
        "responses": {
          "204": { "description": "로그아웃 성공" }
        }
      }
    },
    "/api/users/me": {
      "get": {
        "tags": ["User"],
        "summary": "내 프로필 조회",
        "operationId": "getMyProfile",
        "responses": {
          "200": {
            "description": "프로필 정보",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProfileResponse" } } }
          }
        }
      },
      "patch": {
        "tags": ["User"],
        "summary": "내 프로필 수정",
        "operationId": "updateMyProfile",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProfileUpdateRequest" } } }
        },
        "responses": {
          "200": {
            "description": "수정된 프로필",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProfileResponse" } } }
          }
        }
      }
    },
    "/api/users/me/character": {
      "get": {
        "tags": ["Character"],
        "summary": "내 캐릭터 레이어 조회",
        "operationId": "getMyCharacter",
        "responses": {
          "200": {
            "description": "캐릭터 레이어 정보",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterResponse" } } }
          }
        }
      },
      "put": {
        "tags": ["Character"],
        "summary": "내 캐릭터 레이어 변경",
        "operationId": "updateMyCharacter",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterUpdateRequest" } } }
        },
        "responses": {
          "200": {
            "description": "변경된 캐릭터",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterResponse" } } }
          }
        }
      }
    },
    "/api/users/me/friend-code": {
      "get": {
        "tags": ["Friend"],
        "summary": "내 친구 코드 조회",
        "operationId": "getMyFriendCode",
        "responses": {
          "200": {
            "description": "친구 코드",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FriendCodeResponse" } } }
          }
        }
      }
    },
    "/api/friends": {
      "get": {
        "tags": ["Friend"],
        "summary": "친구 목록 조회 (온라인/공부 상태 포함)",
        "operationId": "getFriends",
        "responses": {
          "200": {
            "description": "친구 목록",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/FriendResponse" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Friend"],
        "summary": "친구 코드로 친구 추가",
        "operationId": "addFriend",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AddFriendRequest" } } }
        },
        "responses": {
          "201": {
            "description": "친구 추가 성공",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FriendResponse" } } }
          },
          "404": { "description": "존재하지 않는 친구 코드" }
        }
      }
    },
    "/api/character-items": {
      "get": {
        "tags": ["Character"],
        "summary": "캐릭터 아이템 목록 조회",
        "operationId": "getItems",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "description": "카테고리 필터 (없으면 전체)",
            "schema": { "$ref": "#/components/schemas/ItemCategory" }
          }
        ],
        "responses": {
          "200": {
            "description": "아이템 목록",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CharacterItemResponse" } }
              }
            }
          }
        }
      }
    },
    "/api/admin/character-items": {
      "post": {
        "tags": ["Admin"],
        "summary": "캐릭터 아이템 등록 (Admin)",
        "operationId": "createItem",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterItemRequest" } } }
        },
        "responses": {
          "201": {
            "description": "등록된 아이템",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterItemResponse" } } }
          },
          "403": { "description": "관리자 권한 없음" }
        }
      }
    },
    "/api/admin/character-items/{id}": {
      "put": {
        "tags": ["Admin"],
        "summary": "캐릭터 아이템 수정 (Admin)",
        "operationId": "updateItem",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterItemRequest" } } }
        },
        "responses": {
          "200": {
            "description": "수정된 아이템",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterItemResponse" } } }
          },
          "403": { "description": "관리자 권한 없음" },
          "404": { "description": "아이템 없음" }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "캐릭터 아이템 삭제 (Admin)",
        "operationId": "deleteItem",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "204": { "description": "삭제 성공" },
          "403": { "description": "관리자 권한 없음" },
          "404": { "description": "아이템 없음" }
        }
      }
    },
    "/api/rooms": {
      "get": {
        "tags": ["Room"],
        "summary": "방 목록 조회",
        "operationId": "getRooms",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "description": "방 유형 필터 (MAJOR | CUSTOM). 없으면 전체.",
            "schema": { "type": "string", "enum": ["MAJOR", "CUSTOM"] }
          },
          {
            "name": "major",
            "in": "query",
            "description": "전공 필터 (type=MAJOR 일 때 사용)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "방 목록",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/RoomResponse" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Room"],
        "summary": "방 생성 (MAJOR / CUSTOM)",
        "operationId": "createRoom",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateRoomRequest" } } }
        },
        "responses": {
          "201": {
            "description": "생성된 방",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RoomResponse" } } }
          }
        }
      }
    },
    "/api/rooms/{roomId}": {
      "get": {
        "tags": ["Room"],
        "summary": "방 상세 조회 (멤버 현재 상태 포함)",
        "operationId": "getRoom",
        "parameters": [
          { "name": "roomId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "방 상세 정보 (현재 멤버 상태 스냅샷 포함)",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RoomDetailResponse" } } }
          },
          "404": { "description": "방 없음" }
        }
      }
    },
    "/api/rooms/{roomId}/join": {
      "post": {
        "tags": ["Room"],
        "summary": "방 입장 (room_members 등록 + STOMP 브로드캐스트)",
        "operationId": "joinRoom",
        "parameters": [
          { "name": "roomId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "입장 성공" },
          "404": { "description": "방 없음" }
        }
      }
    },
    "/api/rooms/{roomId}/leave": {
      "delete": {
        "tags": ["Room"],
        "summary": "방 퇴장 (room_members 삭제 + STOMP 브로드캐스트)",
        "operationId": "leaveRoom",
        "parameters": [
          { "name": "roomId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "204": { "description": "퇴장 성공" },
          "404": { "description": "방 없음" }
        }
      }
    },
    "/api/stats/me": {
      "get": {
        "tags": ["Stats"],
        "summary": "내 학습 통계 조회",
        "operationId": "getMyStats",
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "description": "조회 기간 (WEEKLY, MONTHLY)",
            "schema": { "type": "string", "enum": ["WEEKLY", "MONTHLY"], "default": "WEEKLY" }
          }
        ],
        "responses": {
          "200": {
            "description": "통계 데이터",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StatsResponse" } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UserResponse": {
        "type": "object",
        "properties": {
          "id":          { "type": "string", "format": "uuid" },
          "email":       { "type": "string", "format": "email" },
          "nickname":    { "type": "string" },
          "major":       { "type": "string" },
          "nationality": { "type": "string", "description": "ISO 3166-1 alpha-2 국가 코드" },
          "gender":      { "type": "string", "enum": ["MALE", "FEMALE", "OTHER", "PREFER_NOT_TO_SAY"] }
        }
      },
      "ProfileResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/UserResponse" },
          {
            "type": "object",
            "properties": {
              "friendCode": { "type": "string" },
              "character":  { "$ref": "#/components/schemas/CharacterResponse" }
            }
          }
        ]
      },
      "ProfileUpdateRequest": {
        "type": "object",
        "properties": {
          "nickname":    { "type": "string", "minLength": 2, "maxLength": 20 },
          "major":       { "type": "string" },
          "nationality": { "type": "string" },
          "gender":      { "type": "string", "enum": ["MALE", "FEMALE", "OTHER", "PREFER_NOT_TO_SAY"] }
        }
      },
      "CharacterResponse": {
        "type": "object",
        "description": "레이어 순서: bottom → top → shoes → hair → bag/glasses/item. 각 레이어 값은 CloudFront 전체 URL (null = 미장착)",
        "properties": {
          "gender":  { "type": "string", "nullable": true },
          "bottom":  { "type": "string", "format": "uri", "nullable": true },
          "top":     { "type": "string", "format": "uri", "nullable": true },
          "shoes":   { "type": "string", "format": "uri", "nullable": true },
          "hair":    { "type": "string", "format": "uri", "nullable": true },
          "bag":     { "type": "string", "format": "uri", "nullable": true },
          "glasses": { "type": "string", "format": "uri", "nullable": true },
          "item":    { "type": "string", "format": "uri", "nullable": true }
        }
      },
      "CharacterUpdateRequest": {
        "type": "object",
        "properties": {
          "gender":  { "type": "string", "nullable": true },
          "bottom":  { "type": "string", "nullable": true },
          "top":     { "type": "string", "nullable": true },
          "shoes":   { "type": "string", "nullable": true },
          "hair":    { "type": "string", "nullable": true },
          "bag":     { "type": "string", "nullable": true },
          "glasses": { "type": "string", "nullable": true },
          "item":    { "type": "string", "nullable": true }
        }
      },
      "ItemCategory": {
        "type": "string",
        "enum": ["BOTTOM", "TOP", "SHOES", "HAIR", "BAG", "GLASSES", "ITEM"]
      },
      "CharacterItemRequest": {
        "type": "object",
        "required": ["category", "name", "price", "filePath"],
        "properties": {
          "category": { "$ref": "#/components/schemas/ItemCategory" },
          "name":     { "type": "string" },
          "price":    { "type": "integer" },
          "filePath": { "type": "string", "description": "S3 키 경로 (상대 경로, 예: hair/001.png). 서버가 CloudFront URL로 변환하여 저장." }
        }
      },
      "CharacterItemResponse": {
        "type": "object",
        "properties": {
          "id":       { "type": "string", "format": "uuid" },
          "category": { "$ref": "#/components/schemas/ItemCategory" },
          "name":     { "type": "string" },
          "price":    { "type": "integer" },
          "filePath": { "type": "string", "format": "uri", "description": "CloudFront 전체 URL (예: https://cdn.majormate.com/hair/001.png)" }
        }
      },
      "FriendCodeResponse": {
        "type": "object",
        "properties": {
          "friendCode": { "type": "string", "example": "ABCD1234" }
        }
      },
      "FriendResponse": {
        "type": "object",
        "properties": {
          "userId":       { "type": "string", "format": "uuid" },
          "nickname":     { "type": "string" },
          "major":        { "type": "string" },
          "status":       { "type": "string", "enum": ["OFFLINE", "STUDYING", "PAUSED"] },
          "studyKeyword": { "type": "string", "nullable": true }
        }
      },
      "AddFriendRequest": {
        "type": "object",
        "required": ["friendCode"],
        "properties": {
          "friendCode": { "type": "string" }
        }
      },
      "RoomResponse": {
        "type": "object",
        "properties": {
          "id":          { "type": "string", "format": "uuid" },
          "name":        { "type": "string" },
          "type":        { "type": "string", "enum": ["MAJOR", "CUSTOM"] },
          "major":       { "type": "string", "nullable": true },
          "memberCount": { "type": "integer" },
          "maxMembers":  { "type": "integer" }
        }
      },
      "RoomDetailResponse": {
        "type": "object",
        "properties": {
          "id":          { "type": "string", "format": "uuid" },
          "name":        { "type": "string" },
          "type":        { "type": "string", "enum": ["MAJOR", "CUSTOM"] },
          "major":       { "type": "string", "nullable": true },
          "memberCount": { "type": "integer" },
          "maxMembers":  { "type": "integer" },
          "members": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/RoomMemberStatusResponse" }
          }
        }
      },
      "RoomMemberStatusResponse": {
        "type": "object",
        "properties": {
          "userId":               { "type": "string", "format": "uuid" },
          "nickname":             { "type": "string" },
          "status":               { "type": "string", "enum": ["OFFLINE", "STUDYING", "PAUSED"] },
          "keyword":              { "type": "string", "nullable": true },
          "allowQuestion":        { "type": "boolean" },
          "currentStartTimeEpoch": { "type": "integer", "format": "int64", "nullable": true, "description": "공부 중인 경우 현재 구간의 시작 epoch(ms)" },
          "accumulatedMs":        { "type": "integer", "format": "int64", "description": "이전 구간 누적 경과 ms" }
        }
      },
      "CreateRoomRequest": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name":       { "type": "string", "minLength": 1, "maxLength": 100 },
          "type":       { "type": "string", "enum": ["MAJOR", "CUSTOM"] },
          "major":      { "type": "string", "nullable": true, "description": "type=MAJOR 일 때 필수" },
          "maxMembers": { "type": "integer", "default": 30 }
        }
      },
      "StartStopwatchRequest": {
        "type": "object",
        "description": "STOMP `/app/stopwatch.start` payload",
        "required": ["roomId"],
        "properties": {
          "roomId":        { "type": "string", "format": "uuid" },
          "keyword":       { "type": "string", "nullable": true },
          "allowQuestion": { "type": "boolean", "default": false }
        }
      },
      "UpdateKeywordRequest": {
        "type": "object",
        "description": "STOMP `/app/stopwatch.keyword` payload",
        "required": ["keyword"],
        "properties": {
          "keyword": { "type": "string" }
        }
      },
      "RoomBroadcastMessage": {
        "type": "object",
        "description": "STOMP `/topic/room.{roomId}` 브로드캐스트 메시지",
        "properties": {
          "type":                 { "type": "string", "enum": ["MEMBER_JOINED","MEMBER_LEFT","MEMBER_STARTED","MEMBER_PAUSED","MEMBER_RESUMED","MEMBER_ENDED","MEMBER_KEYWORD_UPDATED"] },
          "userId":               { "type": "string", "format": "uuid" },
          "nickname":             { "type": "string" },
          "status":               { "type": "string", "enum": ["OFFLINE","STUDYING","PAUSED"] },
          "keyword":              { "type": "string", "nullable": true },
          "allowQuestion":        { "type": "boolean" },
          "currentStartTimeEpoch": { "type": "integer", "format": "int64", "nullable": true },
          "accumulatedMs":        { "type": "integer", "format": "int64" }
        }
      },
      "StatsResponse": {
        "type": "object",
        "properties": {
          "period":       { "type": "string", "enum": ["WEEKLY", "MONTHLY"] },
          "totalSeconds": { "type": "integer" },
          "dailyBreakdown": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date":    { "type": "string", "format": "date" },
                "seconds": { "type": "integer" }
              }
            }
          },
          "topKeywords": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "keyword": { "type": "string" },
                "count":   { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "JSESSIONID"
      }
    }
  },
  "security": [{ "cookieAuth": [] }]
}
