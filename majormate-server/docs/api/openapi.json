{
  "openapi": "3.1.0",
  "info": {
    "title": "MajorMate API",
    "description": "Global Major-based Study Platform — Backend API",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:8080", "description": "Local Dev" }
  ],
  "tags": [
    { "name": "Auth",      "description": "Google OAuth2 인증" },
    { "name": "User",      "description": "사용자 프로필" },
    { "name": "Character", "description": "캐릭터 레이어 시스템" },
    { "name": "Friend",    "description": "친구 코드 & 네트워킹" },
    { "name": "Room",      "description": "전공방 & 커스텀 스터디룸" },
    { "name": "Session",   "description": "스톱워치 세션" },
    { "name": "Stats",     "description": "학습 통계" },
    { "name": "Admin",     "description": "관리자 전용 API" }
  ],
  "paths": {
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "현재 인증된 사용자 정보 조회",
        "operationId": "getMe",
        "responses": {
          "200": {
            "description": "인증된 사용자",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserResponse" } } }
          },
          "401": { "description": "미인증" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그아웃",
        "operationId": "logout",
        "responses": {
          "204": { "description": "로그아웃 성공" }
        }
      }
    },
    "/api/users/me": {
      "get": {
        "tags": ["User"],
        "summary": "내 프로필 조회",
        "operationId": "getMyProfile",
        "responses": {
          "200": {
            "description": "프로필 정보",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProfileResponse" } } }
          }
        }
      },
      "patch": {
        "tags": ["User"],
        "summary": "내 프로필 수정",
        "operationId": "updateMyProfile",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProfileUpdateRequest" } } }
        },
        "responses": {
          "200": {
            "description": "수정된 프로필",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProfileResponse" } } }
          }
        }
      }
    },
    "/api/users/me/character": {
      "get": {
        "tags": ["Character"],
        "summary": "내 캐릭터 레이어 조회",
        "operationId": "getMyCharacter",
        "responses": {
          "200": {
            "description": "캐릭터 레이어 정보",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterResponse" } } }
          }
        }
      },
      "put": {
        "tags": ["Character"],
        "summary": "내 캐릭터 레이어 변경",
        "operationId": "updateMyCharacter",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterUpdateRequest" } } }
        },
        "responses": {
          "200": {
            "description": "변경된 캐릭터",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterResponse" } } }
          }
        }
      }
    },
    "/api/users/me/friend-code": {
      "get": {
        "tags": ["Friend"],
        "summary": "내 친구 코드 조회",
        "operationId": "getMyFriendCode",
        "responses": {
          "200": {
            "description": "친구 코드",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FriendCodeResponse" } } }
          }
        }
      }
    },
    "/api/friends": {
      "get": {
        "tags": ["Friend"],
        "summary": "친구 목록 조회 (온라인/공부 상태 포함)",
        "operationId": "getFriends",
        "responses": {
          "200": {
            "description": "친구 목록",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/FriendResponse" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Friend"],
        "summary": "친구 코드로 친구 추가",
        "operationId": "addFriend",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AddFriendRequest" } } }
        },
        "responses": {
          "201": {
            "description": "친구 추가 성공",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FriendResponse" } } }
          },
          "404": { "description": "존재하지 않는 친구 코드" }
        }
      }
    },
    "/api/character-items": {
      "get": {
        "tags": ["Character"],
        "summary": "캐릭터 아이템 목록 조회",
        "operationId": "getItems",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "description": "카테고리 필터 (없으면 전체)",
            "schema": { "$ref": "#/components/schemas/ItemCategory" }
          }
        ],
        "responses": {
          "200": {
            "description": "아이템 목록",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CharacterItemResponse" } }
              }
            }
          }
        }
      }
    },
    "/api/admin/character-items": {
      "post": {
        "tags": ["Admin"],
        "summary": "캐릭터 아이템 등록 (Admin)",
        "operationId": "createItem",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterItemRequest" } } }
        },
        "responses": {
          "201": {
            "description": "등록된 아이템",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterItemResponse" } } }
          },
          "403": { "description": "관리자 권한 없음" }
        }
      }
    },
    "/api/admin/character-items/{id}": {
      "put": {
        "tags": ["Admin"],
        "summary": "캐릭터 아이템 수정 (Admin)",
        "operationId": "updateItem",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterItemRequest" } } }
        },
        "responses": {
          "200": {
            "description": "수정된 아이템",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CharacterItemResponse" } } }
          },
          "403": { "description": "관리자 권한 없음" },
          "404": { "description": "아이템 없음" }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "캐릭터 아이템 삭제 (Admin)",
        "operationId": "deleteItem",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "204": { "description": "삭제 성공" },
          "403": { "description": "관리자 권한 없음" },
          "404": { "description": "아이템 없음" }
        }
      }
    },
    "/api/rooms/major": {
      "get": {
        "tags": ["Room"],
        "summary": "전공방 목록 조회",
        "operationId": "getMajorRooms",
        "parameters": [
          {
            "name": "major",
            "in": "query",
            "description": "전공 필터 (없으면 전체)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "전공방 목록",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/RoomResponse" } }
              }
            }
          }
        }
      }
    },
    "/api/rooms/custom": {
      "post": {
        "tags": ["Room"],
        "summary": "커스텀 방 생성",
        "operationId": "createCustomRoom",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateRoomRequest" } } }
        },
        "responses": {
          "201": {
            "description": "생성된 방",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RoomResponse" } } }
          }
        }
      }
    },
    "/api/rooms/{roomId}": {
      "get": {
        "tags": ["Room"],
        "summary": "방 상세 조회",
        "operationId": "getRoom",
        "parameters": [
          { "name": "roomId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "방 정보",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RoomResponse" } } }
          },
          "404": { "description": "방 없음" }
        }
      }
    },
    "/api/rooms/{roomId}/join": {
      "post": {
        "tags": ["Room"],
        "summary": "방 입장",
        "operationId": "joinRoom",
        "parameters": [
          { "name": "roomId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "입장 성공" },
          "404": { "description": "방 없음" }
        }
      }
    },
    "/api/rooms/{roomId}/leave": {
      "post": {
        "tags": ["Room"],
        "summary": "방 퇴장",
        "operationId": "leaveRoom",
        "parameters": [
          { "name": "roomId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "204": { "description": "퇴장 성공" }
        }
      }
    },
    "/api/study-sessions/start": {
      "post": {
        "tags": ["Session"],
        "summary": "스톱워치 세션 시작",
        "operationId": "startSession",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StartSessionRequest" } } }
        },
        "responses": {
          "201": {
            "description": "세션 시작됨",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StudySessionResponse" } } }
          }
        }
      }
    },
    "/api/study-sessions/stop": {
      "post": {
        "tags": ["Session"],
        "summary": "스톱워치 세션 종료",
        "operationId": "stopSession",
        "responses": {
          "200": {
            "description": "세션 종료됨",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StudySessionResponse" } } }
          }
        }
      }
    },
    "/api/stats/me": {
      "get": {
        "tags": ["Stats"],
        "summary": "내 학습 통계 조회",
        "operationId": "getMyStats",
        "parameters": [
          {
            "name": "period",
            "in": "query",
            "description": "조회 기간 (WEEKLY, MONTHLY)",
            "schema": { "type": "string", "enum": ["WEEKLY", "MONTHLY"], "default": "WEEKLY" }
          }
        ],
        "responses": {
          "200": {
            "description": "통계 데이터",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/StatsResponse" } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "UserResponse": {
        "type": "object",
        "properties": {
          "id":       { "type": "string", "format": "uuid" },
          "email":    { "type": "string", "format": "email" },
          "nickname": { "type": "string" },
          "major":    { "type": "string" },
          "nationality": { "type": "string", "description": "ISO 3166-1 alpha-2 국가 코드" },
          "gender":   { "type": "string", "enum": ["MALE", "FEMALE", "OTHER", "PREFER_NOT_TO_SAY"] }
        }
      },
      "ProfileResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/UserResponse" },
          {
            "type": "object",
            "properties": {
              "friendCode": { "type": "string" },
              "character":  { "$ref": "#/components/schemas/CharacterResponse" }
            }
          }
        ]
      },
      "ProfileUpdateRequest": {
        "type": "object",
        "properties": {
          "nickname":    { "type": "string", "minLength": 2, "maxLength": 20 },
          "major":       { "type": "string" },
          "nationality": { "type": "string" },
          "gender":      { "type": "string", "enum": ["MALE", "FEMALE", "OTHER", "PREFER_NOT_TO_SAY"] }
        }
      },
      "CharacterResponse": {
        "type": "object",
        "description": "레이어 순서: bottom → top → shoes → hair → bag/glasses/item",
        "properties": {
          "gender":   { "type": "string", "nullable": true },
          "bottom":   { "type": "string", "nullable": true },
          "top":      { "type": "string", "nullable": true },
          "shoes":    { "type": "string", "nullable": true },
          "hair":     { "type": "string", "nullable": true },
          "bag":      { "type": "string", "nullable": true },
          "glasses":  { "type": "string", "nullable": true },
          "item":     { "type": "string", "nullable": true }
        }
      },
      "CharacterUpdateRequest": {
        "type": "object",
        "properties": {
          "gender":   { "type": "string", "nullable": true },
          "bottom":   { "type": "string", "nullable": true },
          "top":      { "type": "string", "nullable": true },
          "shoes":    { "type": "string", "nullable": true },
          "hair":     { "type": "string", "nullable": true },
          "bag":      { "type": "string", "nullable": true },
          "glasses":  { "type": "string", "nullable": true },
          "item":     { "type": "string", "nullable": true }
        }
      },
      "ItemCategory": {
        "type": "string",
        "enum": ["BOTTOM", "TOP", "SHOES", "HAIR", "BAG", "GLASSES", "ITEM"]
      },
      "CharacterItemRequest": {
        "type": "object",
        "required": ["category", "name", "price", "filePath"],
        "properties": {
          "category": { "$ref": "#/components/schemas/ItemCategory" },
          "name":     { "type": "string" },
          "price":    { "type": "integer" },
          "filePath": { "type": "string" }
        }
      },
      "CharacterItemResponse": {
        "type": "object",
        "properties": {
          "id":       { "type": "string", "format": "uuid" },
          "category": { "$ref": "#/components/schemas/ItemCategory" },
          "name":     { "type": "string" },
          "price":    { "type": "integer" },
          "filePath": { "type": "string" }
        }
      },
      "FriendCodeResponse": {
        "type": "object",
        "properties": {
          "friendCode": { "type": "string", "example": "ABCD1234" }
        }
      },
      "FriendResponse": {
        "type": "object",
        "properties": {
          "userId":   { "type": "string", "format": "uuid" },
          "nickname": { "type": "string" },
          "major":    { "type": "string" },
          "status":   { "type": "string", "enum": ["OFFLINE", "STUDYING"] },
          "studyKeyword": { "type": "string", "nullable": true }
        }
      },
      "AddFriendRequest": {
        "type": "object",
        "required": ["friendCode"],
        "properties": {
          "friendCode": { "type": "string" }
        }
      },
      "RoomResponse": {
        "type": "object",
        "properties": {
          "id":           { "type": "string", "format": "uuid" },
          "name":         { "type": "string" },
          "type":         { "type": "string", "enum": ["MAJOR", "CUSTOM"] },
          "major":        { "type": "string", "nullable": true },
          "participantCount": { "type": "integer" },
          "createdBy":    { "type": "string", "format": "uuid", "nullable": true }
        }
      },
      "CreateRoomRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 50 }
        }
      },
      "StartSessionRequest": {
        "type": "object",
        "properties": {
          "roomId":         { "type": "string", "format": "uuid" },
          "keyword":        { "type": "string", "nullable": true },
          "allowQuestions": { "type": "boolean", "default": false }
        }
      },
      "StudySessionResponse": {
        "type": "object",
        "properties": {
          "sessionId":  { "type": "string", "format": "uuid" },
          "startedAt":  { "type": "string", "format": "date-time" },
          "endedAt":    { "type": "string", "format": "date-time", "nullable": true },
          "durationSeconds": { "type": "integer", "nullable": true },
          "keyword":    { "type": "string", "nullable": true }
        }
      },
      "StatsResponse": {
        "type": "object",
        "properties": {
          "period":           { "type": "string", "enum": ["WEEKLY", "MONTHLY"] },
          "totalSeconds":     { "type": "integer" },
          "dailyBreakdown":   {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date":    { "type": "string", "format": "date" },
                "seconds": { "type": "integer" }
              }
            }
          },
          "topKeywords": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "keyword": { "type": "string" },
                "count":   { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "JSESSIONID"
      }
    }
  },
  "security": [{ "cookieAuth": [] }]
}
