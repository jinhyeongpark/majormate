# Google OAuth Client IDs (expo-auth-session)
# Expo Go (dev): Web application 타입, redirect URI에 https://auth.expo.io/@<username>/majormate 추가
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Android native build용 (Android 앱 타입)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# iOS native build용 (iOS 앱 타입)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
