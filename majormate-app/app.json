{
  "expo": {
    "name": "MajorMate",
    "slug": "majormate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "me.majormate.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "me.majormate.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "majormate",
    "plugins": [
      "expo-router"
    ]
  }
}
